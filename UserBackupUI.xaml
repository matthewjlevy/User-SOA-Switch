<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entra ID User Sync Attribute Backup - Multi-User Selection" Height="820" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Load Users Section -->
        <GroupBox Header="User Management" Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Name="btnConnect" Grid.Column="0" Content="Connect to Graph" 
                        Height="35" Margin="0,0,5,0" FontWeight="Bold"/>
                <Button Name="btnDisconnect" Grid.Column="1" Content="Disconnect" 
                        Height="35" Margin="5,0" IsEnabled="False" FontWeight="Bold"/>
                <Button Name="btnLoadUsers" Grid.Column="2" Content="Load Synced Users" 
                        Height="35" Margin="5,0" IsEnabled="False" FontWeight="Bold"/>
                <Button Name="btnLoadCloudUsers" Grid.Column="3" Content="Load Cloud Users" 
                        Height="35" Margin="5,0" IsEnabled="False" FontWeight="Bold"/>
                <Button Name="btnRefresh" Grid.Column="4" Content="Refresh" 
                        Height="35" Margin="5,0,0,0" IsEnabled="False" HorizontalAlignment="Left" Width="100"/>
            </Grid>
        </GroupBox>

        <!-- Connection Status and Filter Section -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Connection Status -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Label Content="Status:" FontWeight="Bold"/>
                <Label Name="lblConnectionStatus" Content="Not Connected" Foreground="Red"/>
                <Label Content=" | User:" FontWeight="Bold" Margin="20,0,0,0"/>
                <Label Name="lblConnectedUser" Content="N/A" Foreground="Gray"/>
            </StackPanel>
            
            <!-- Filter Section -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Label Content="Filter by Display Name:" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Name="txtFilterUsers" Width="250" Height="25" Margin="5,0"
                         ToolTip="Enter 3 or more characters to filter users" IsEnabled="False"/>
                <Button Name="btnClearFilter" Content="Clear Filter" Width="100" Height="25" 
                        Margin="5,0,0,0" IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <!-- User Counts and Selection Controls -->
        <Border Grid.Row="2" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="1" 
                Padding="10,5" Margin="0,0,0,5">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Total Users: " FontWeight="Bold"/>
                    <TextBlock Name="txtTotalCount" Text="0" Margin="0,0,15,0"/>
                    <TextBlock Text="Filtered: " FontWeight="Bold"/>
                    <TextBlock Name="txtFilteredCount" Text="0" Margin="0,0,15,0"/>
                    <TextBlock Text="Selected: " FontWeight="Bold" Foreground="#0066CC"/>
                    <TextBlock Name="txtSelectedCount" Text="0" Foreground="#0066CC" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="btnSelectAll" Content="Select All Visible" Width="130" Height="28" 
                            Margin="0,0,5,0" IsEnabled="False"/>
                    <Button Name="btnSelectNone" Content="Clear All Selections" Width="130" Height="28" 
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid with Progress Overlay -->
        <Grid Grid.Row="3">
            <!-- DataGrid for Users -->
            <DataGrid Name="dgUsers" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="#F5F5F5"
                      HeadersVisibility="Column"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓" Width="40" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}"/>
                    <DataGridTextColumn Header="Display Name" Width="220" Binding="{Binding DisplayName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="User Principal Name" Width="280" Binding="{Binding UserPrincipalName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="SAM Account" Width="150" Binding="{Binding OnPremisesSamAccountName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="On-Premises Sync Enabled" Width="180" Binding="{Binding OnPremisesSyncEnabled}" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Last Sync" Width="160" Binding="{Binding OnPremisesLastSyncDateTime}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Domain" Width="180" Binding="{Binding OnPremisesDomainName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Account Enabled" Width="120" Binding="{Binding AccountEnabled}" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
            
            <!-- Progress Overlay -->
            <Border Name="pnlProgress" Background="#E0FFFFFF" Visibility="Collapsed" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Name="txtProgressStatus" Text="Loading synced users..." 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,10" 
                               HorizontalAlignment="Center"/>
                    <ProgressBar Name="pbProgress" Width="400" Height="25" 
                                 Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock Name="txtProgressDetail" Text="" 
                               FontSize="12" Margin="0,10,0,0" 
                               HorizontalAlignment="Center" Foreground="Gray"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SOA Warning Banner -->
        <Border Grid.Row="4" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1,1,1,0"
                Padding="10,8" Margin="0,5,0,0">
            <StackPanel>
                <TextBlock Text="⚠  SOURCE OF AUTHORITY (SOA) MANAGEMENT — ADVANCED OPERATIONS"
                           FontWeight="Bold" Foreground="#856404" FontSize="12"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,3,0,0" Foreground="#856404"
                           Text="PREREQUISITE SEQUENCE: (1) Backup user attributes  → (2) Switch SOA to Cloud. → (3) Clear On-Prem Attributes.   Ensure each user is excluded from on-premises AD sync before switching SOA. These operations are irreversible without a valid backup."/>
            </StackPanel>
        </Border>

        <!-- SOA Action Buttons -->
        <Border Grid.Row="5" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1,0,1,1"
                Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Name="btnClearAttributes" Content="Clear On-Prem Attributes"
                        Width="200" Height="35" Margin="0,0,8,0" IsEnabled="False"
                        FontWeight="Bold" Background="#DC3545" Foreground="White" BorderBrush="#C82333"/>
                <Button Name="btnSwitchSOA" Content="Switch SOA to Cloud"
                        Width="180" Height="35" Margin="0,0,8,0" IsEnabled="False"
                        FontWeight="Bold" Background="#6F42C1" Foreground="White" BorderBrush="#5A32A3"/>
                <Button Name="btnRollbackSOA" Content="Rollback SOA to On-Prem"
                        Width="195" Height="35" Margin="0,0,8,0" IsEnabled="False"
                        FontWeight="Bold" Background="#FF8C00" Foreground="White" BorderBrush="#E67E00"/>
                <Button Name="btnRestoreBackup" Content="Restore from Backup"
                        Width="180" Height="35" Margin="0,0,0,0" IsEnabled="False"
                        FontWeight="Bold" Background="#28A745" Foreground="White" BorderBrush="#1E7E34"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" 
                    Margin="0,10,0,10">
            <Button Name="btnBackup" Content="Backup Selected Users (0)" Width="200" Height="38" 
                    Margin="5,0" IsEnabled="False" FontWeight="Bold" FontSize="13"/>
            <Button Name="btnClose" Content="Close" Width="100" Height="38" 
                    Margin="5,0" IsCancel="True"/>
        </StackPanel>

        <!-- Status Bar -->
        <Border Grid.Row="7" Background="#F0F0F0" BorderBrush="#CCCCCC" 
                BorderThickness="0,1,0,0" Padding="5">
            <TextBlock Name="txtStatusBar" Text="Ready. Click 'Connect to Graph' to begin." 
                       FontStyle="Italic"/>
        </Border>
    </Grid>
</Window>